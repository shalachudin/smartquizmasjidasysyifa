import React, { useState, useEffect, useRef } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInAnonymously, 
  signInWithCustomToken, 
  onAuthStateChanged 
} from 'firebase/auth';
import { 
  getFirestore, 
  doc, 
  setDoc, 
  onSnapshot, 
  updateDoc, 
  collection, 
  query, 
  getDocs,
  runTransaction
} from 'firebase/firestore';
import { 
  Trophy, 
  Timer, 
  User, 
  CheckCircle2, 
  AlertTriangle, 
  Settings,
  BookOpen,
  Award,
  ChevronRight
} from 'lucide-react';

// Firebase Configuration
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'smart-quiz-pai-001';

// Bank Soal PAI SD (Vignette)
const QUESTION_BANK = [
  {
    id: 1,
    category: "Aqidah",
    vignette: "Ahmad melihat pelangi yang sangat indah setelah hujan. Ia sadar bahwa keindahan itu adalah ciptaan Allah SWT yang Maha Kuasa.",
    question: "Sifat Allah yang ditunjukkan dalam cerita tersebut adalah...",
    options: ["Al-Khaliq", "Al-Bashir", "As-Sami", "Al-Ahad"],
    correct: 0,
    timeLimit: 45
  },
  {
    id: 2,
    category: "Akhlak",
    vignette: "Saat istirahat, Budi menemukan uang Rp 10.000 di kantin sekolah. Meskipun tidak ada yang melihat, ia menyerahkannya ke guru piket.",
    question: "Sifat mulia yang dipraktikkan Budi disebut...",
    options: ["Sabar", "Amanah/Jujur", "Tawadhu", "Qana'ah"],
    correct: 1,
    timeLimit: 45
  },
  {
    id: 3,
    category: "Tajwid",
    vignette: "Dalam membaca Surah Al-Ikhlas, terdapat pertemuan huruf Nun mati atau Tanwin dengan huruf-huruf tertentu yang dibaca jelas.",
    question: "Hukum bacaan Nun mati yang dibaca dengan jelas (tanpa dengung) disebut...",
    options: ["Idgham Bighunnah", "Ikhfa", "Izhhar Halqi", "Iqlab"],
    correct: 2,
    timeLimit: 30
  },
  {
    id: 4,
    category: "Sirah",
    vignette: "Nabi Muhammad SAW dikenal sebagai orang yang sangat terpercaya sejak muda, bahkan sebelum diangkat menjadi Rasul.",
    question: "Gelar yang diberikan penduduk Mekkah kepada beliau adalah...",
    options: ["As-Siddiq", "Al-Amin", "Al-Faruq", "Dzunnurain"],
    correct: 1,
    timeLimit: 45
  },
  {
    id: 5,
    category: "Hadits",
    vignette: "Rasulullah bersabda bahwa kebersihan itu adalah sebagian dari iman.",
    question: "Istilah bahasa Arab yang tepat untuk 'Kebersihan' dalam konteks hadits tersebut adalah...",
    options: ["At-Thaharu", "Al-Birru", "Al-Ilmu", "As-Shabru"],
    correct: 0,
    timeLimit: 30
  }
];

export default function App() {
  const [user, setUser] = useState(null);
  const [role, setRole] = useState(null); // 'server' or 'participant'
  const [gameState, setGameState] = useState(null);
  const [participants, setParticipants] = useState([]);
  const [playerName, setPlayerName] = useState('');
  const [isJoined, setIsJoined] = useState(false);
  const [warningCount, setWarningCount] = useState(0);
  const [isLocked, setIsLocked] = useState(false);
  const [lastAnswerIndex, setLastAnswerIndex] = useState(-1);

  // RULE 3: Initial Auth
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Auth error:", err);
      }
    };
    initAuth();
    const unsub = onAuthStateChanged(auth, (u) => setUser(u));
    return () => unsub();
  }, []);

  // RULE 1 & 2: Listen to Game State
  useEffect(() => {
    if (!user) return;
    // Menggunakan segment genap: artifacts/{appId}/public/data/gameSession/gameConfig
    const gameRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameSession', 'gameConfig');
    
    const unsub = onSnapshot(gameRef, (docSnap) => {
      if (docSnap.exists()) {
        setGameState(docSnap.data());
      } else if (role === 'server') {
        // Initial setup for server only
        setDoc(gameRef, {
          status: 'lobby',
          currentQuestionIndex: 0,
          startTime: Date.now(),
          totalQuestions: QUESTION_BANK.length,
          timeRemaining: 60
        });
      }
    }, (err) => console.error("Firestore State Error:", err));

    return () => unsub();
  }, [user, role]);

  // Listen to Participants
  useEffect(() => {
    if (!user || role !== 'server') return;
    const participantsRef = collection(db, 'artifacts', appId, 'public', 'data', 'participants');
    const unsub = onSnapshot(participantsRef, (snapshot) => {
      const data = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
      setParticipants(data);
    }, (err) => console.error("Participants Listener Error:", err));
    return () => unsub();
  }, [user, role]);

  // Anti-Multitasking
  useEffect(() => {
    if (role === 'participant' && isJoined && !isLocked) {
      const handleVisibilityChange = () => {
        if (document.hidden) {
          setWarningCount(prev => {
            const newCount = prev + 1;
            if (newCount >= 3) setIsLocked(true);
            return newCount;
          });
        }
      };
      window.addEventListener('visibilitychange', handleVisibilityChange);
      return () => window.removeEventListener('visibilitychange', handleVisibilityChange);
    }
  }, [role, isJoined, isLocked]);

  // Server Timer Logic
  useEffect(() => {
    let timer;
    if (role === 'server' && gameState?.status === 'playing' && gameState?.timeRemaining > 0) {
      timer = setInterval(async () => {
        const gameRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameSession', 'gameConfig');
        await updateDoc(gameRef, { timeRemaining: gameState.timeRemaining - 1 });
      }, 1000);
    } else if (role === 'server' && gameState?.status === 'playing' && gameState?.timeRemaining === 0) {
      handleNextQuestion();
    }
    return () => clearInterval(timer);
  }, [role, gameState?.status, gameState?.timeRemaining]);

  const handleNextQuestion = async () => {
    const gameRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameSession', 'gameConfig');
    const nextIndex = gameState.currentQuestionIndex + 1;
    
    if (nextIndex < QUESTION_BANK.length) {
      await updateDoc(gameRef, {
        currentQuestionIndex: nextIndex,
        timeRemaining: QUESTION_BANK[nextIndex].timeLimit,
        status: 'playing'
      });
      // Reset participant flags
      const participantsRef = collection(db, 'artifacts', appId, 'public', 'data', 'participants');
      const pSnap = await getDocs(participantsRef);
      for (const pDoc of pSnap.docs) {
        await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'participants', pDoc.id), {
          hasAnswered: false,
          answeredAt: null
        });
      }
    } else {
      await updateDoc(gameRef, { status: 'finished' });
    }
  };

  const joinGame = async () => {
    if (!playerName.trim() || !user) return;
    const pRef = doc(db, 'artifacts', appId, 'public', 'data', 'participants', user.uid);
    await setDoc(pRef, {
      name: playerName,
      score: 0,
      hasAnswered: false,
      answeredAt: null,
      warningCount: 0
    });
    setIsJoined(true);
  };

  const submitAnswer = async (optionIndex) => {
    if (!user || gameState?.status !== 'playing' || lastAnswerIndex === gameState.currentQuestionIndex) return;
    
    const pRef = doc(db, 'artifacts', appId, 'public', 'data', 'participants', user.uid);
    const isCorrect = optionIndex === QUESTION_BANK[gameState.currentQuestionIndex].correct;
    const timeBonus = gameState.timeRemaining;

    try {
      await runTransaction(db, async (transaction) => {
        const pDoc = await transaction.get(pRef);
        if (!pDoc.exists()) return;
        const currentScore = pDoc.data().score || 0;
        transaction.update(pRef, {
          hasAnswered: true,
          answeredAt: Date.now(),
          score: isCorrect ? currentScore + 100 + timeBonus : currentScore
        });
      });
      setLastAnswerIndex(gameState.currentQuestionIndex);
    } catch (e) {
      console.error("Submit Answer Transaction Failed: ", e);
    }
  };

  if (!role) {
    return (
      <div className="min-h-screen bg-emerald-50 flex items-center justify-center p-4 font-sans">
        <div className="bg-white p-8 rounded-3xl shadow-xl max-w-md w-full text-center">
          <h1 className="text-3xl font-bold text-emerald-800 mb-6">Smart Quiz PAI</h1>
          <p className="text-slate-600 mb-8 font-medium">Pilih Mode Perangkat Anda:</p>
          <div className="grid grid-cols-1 gap-4">
            <button 
              onClick={() => setRole('server')}
              className="flex items-center justify-between p-6 bg-emerald-600 text-white rounded-2xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200"
            >
              <div className="text-left">
                <span className="block font-bold text-lg">Mode Server</span>
                <span className="text-emerald-100 text-sm">Tampilkan di Layar Utama</span>
              </div>
              <Settings size={32} />
            </button>
            <button 
              onClick={() => setRole('participant')}
              className="flex items-center justify-between p-6 bg-amber-500 text-white rounded-2xl hover:bg-amber-600 transition shadow-lg shadow-amber-200"
            >
              <div className="text-left">
                <span className="block font-bold text-lg">Mode Peserta</span>
                <span className="text-amber-50 text-sm">Gunakan untuk menjawab</span>
              </div>
              <User size={32} />
            </button>
          </div>
        </div>
      </div>
    );
  }

  // --- VIEW SERVER ---
  if (role === 'server') {
    const currentQ = QUESTION_BANK[gameState?.currentQuestionIndex || 0];
    
    return (
      <div className="min-h-screen bg-slate-900 text-white p-6 overflow-hidden flex flex-col font-sans">
        <div className="flex justify-between items-center mb-8 bg-slate-800 p-4 rounded-2xl border border-slate-700">
          <div className="flex items-center gap-4">
            <div className="bg-emerald-500 p-3 rounded-xl shadow-lg shadow-emerald-500/20">
              <BookOpen size={24} />
            </div>
            <div>
              <h2 className="text-2xl font-bold">Lomba Cerdas Cermat PAI</h2>
              <p className="text-slate-400 text-sm uppercase tracking-widest">{currentQ?.category}</p>
            </div>
          </div>
          <div className="flex items-center gap-6">
            <div className="text-right">
              <p className="text-slate-400 text-xs uppercase font-bold mb-1">Waktu Sisa</p>
              <p className={`text-4xl font-mono font-black ${gameState?.timeRemaining < 10 ? 'text-red-500 animate-pulse' : 'text-amber-400'}`}>
                {gameState?.timeRemaining || 0}s
              </p>
            </div>
            <div className="bg-slate-700 px-6 py-2 rounded-xl border border-slate-600 text-center">
              <p className="text-slate-400 text-xs uppercase font-bold">Soal</p>
              <p className="text-2xl font-bold">{ (gameState?.currentQuestionIndex || 0) + 1 } / {QUESTION_BANK.length}</p>
            </div>
          </div>
        </div>

        {gameState?.status === 'lobby' ? (
          <div className="flex-1 flex flex-col items-center justify-center">
            <h3 className="text-4xl font-bold mb-10 text-emerald-400">Menunggu Peserta Bergabung...</h3>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 w-full max-w-5xl">
              {participants.map(p => (
                <div key={p.id} className="bg-slate-800 p-4 rounded-2xl border border-emerald-500/30 flex items-center gap-3 animate-in fade-in zoom-in duration-300">
                  <div className="w-12 h-12 bg-emerald-500 rounded-full flex items-center justify-center text-xl font-bold text-white shadow-inner">
                    {p.name.charAt(0).toUpperCase()}
                  </div>
                  <span className="font-bold text-lg truncate">{p.name}</span>
                </div>
              ))}
              {participants.length === 0 && <p className="col-span-4 text-center text-slate-500 italic">Belum ada peserta yang masuk.</p>}
            </div>
            <button 
              onClick={async () => {
                const gameRef = doc(db, 'artifacts', appId, 'public', 'data', 'gameSession', 'gameConfig');
                await updateDoc(gameRef, { status: 'playing', timeRemaining: QUESTION_BANK[0].timeLimit });
              }}
              className="mt-16 px-16 py-5 bg-emerald-600 hover:bg-emerald-500 rounded-full font-black text-2xl flex items-center gap-3 transition-all transform hover:scale-105 shadow-xl shadow-emerald-600/20"
            >
              <ChevronRight size={32} /> MULAI LOMBA SEKARANG
            </button>
          </div>
        ) : gameState?.status === 'playing' ? (
          <div className="flex-1 grid grid-cols-12 gap-8">
            <div className="col-span-8 flex flex-col gap-6">
              <div className="bg-white text-slate-900 p-10 rounded-3xl shadow-2xl flex-1 border-b-8 border-emerald-500">
                <div className="bg-emerald-100 text-emerald-700 px-4 py-1 rounded-full text-sm font-black w-fit mb-6 uppercase tracking-wider">
                  KASUS / VIGNETTE
                </div>
                <p className="text-3xl leading-snug mb-10 font-medium italic text-slate-700">
                  "{currentQ?.vignette}"
                </p>
                <div className="h-px bg-slate-100 w-full mb-8"></div>
                <h3 className="text-4xl font-black leading-tight text-slate-900">
                  {currentQ?.question}
                </h3>
              </div>
              <div className="grid grid-cols-2 gap-4">
                {currentQ?.options.map((opt, i) => (
                  <div key={i} className="bg-slate-800 p-6 rounded-2xl border-2 border-slate-700 flex items-center gap-6 shadow-lg">
                    <div className="w-12 h-12 rounded-xl bg-emerald-500 flex items-center justify-center font-black text-2xl text-white">
                      {String.fromCharCode(65 + i)}
                    </div>
                    <span className="text-2xl font-bold">{opt}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className="col-span-4 bg-slate-800/50 rounded-3xl border border-slate-700 p-8">
              <h4 className="text-xl font-black mb-6 flex items-center gap-3 border-b border-slate-700 pb-4">
                <User className="text-emerald-400" /> STATUS JAWABAN
              </h4>
              <div className="space-y-4 overflow-y-auto max-h-[60vh] pr-2">
                {participants.map(p => (
                  <div key={p.id} className={`p-5 rounded-2xl flex items-center justify-between transition-all ${p.hasAnswered ? 'bg-emerald-500/20 border-2 border-emerald-500' : 'bg-slate-800 border border-slate-700 opacity-60'}`}>
                    <span className="font-bold text-lg">{p.name}</span>
                    {p.hasAnswered ? (
                      <div className="flex items-center gap-2 text-emerald-400 font-black">
                        <CheckCircle2 size={24} /> SELESAI
                      </div>
                    ) : (
                      <div className="text-slate-500 text-sm italic font-bold">BERPIKIR...</div>
                    )}
                  </div>
                ))}
              </div>
              <div className="mt-8 pt-6 border-t border-slate-700 text-center">
                <div className="text-4xl font-black text-emerald-400">
                  {participants.filter(p => p.hasAnswered).length} / {participants.length}
                </div>
                <div className="text-slate-400 text-sm font-bold uppercase mt-1">Sudah Menjawab</div>
              </div>
            </div>
          </div>
        ) : (
          <div className="flex-1 flex flex-col items-center justify-center animate-in fade-in duration-1000">
            <Trophy size={140} className="text-amber-400 mb-8 drop-shadow-[0_0_30px_rgba(251,191,36,0.4)]" />
            <h2 className="text-6xl font-black mb-4 text-center text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-yellow-200 to-amber-600">
              HASIL AKHIR LOMBA
            </h2>
            <p className="text-slate-400 text-2xl mb-12 font-medium">Selamat kepada para pemenang!</p>
            
            <div className="w-full max-w-3xl bg-slate-800 rounded-[40px] p-10 border border-slate-700 shadow-2xl">
              <h3 className="text-2xl font-black mb-8 text-center border-b border-slate-700 pb-6 uppercase tracking-widest text-emerald-400">Papan Skor Tertinggi</h3>
              <div className="space-y-5">
                {[...participants].sort((a,b) => b.score - a.score).map((p, idx) => (
                  <div key={p.id} className={`flex items-center justify-between p-6 rounded-3xl ${idx === 0 ? 'bg-amber-500/20 border-2 border-amber-500 ring-4 ring-amber-500/10' : 'bg-slate-700/50 border border-slate-600'}`}>
                    <div className="flex items-center gap-6">
                      <span className={`w-12 h-12 rounded-full flex items-center justify-center font-black text-xl shadow-lg ${idx === 0 ? 'bg-amber-400 text-black' : 'bg-slate-600 text-white'}`}>
                        {idx + 1}
                      </span>
                      <span className="text-2xl font-black">{p.name}</span>
                    </div>
                    <div className="text-right">
                      <span className="text-3xl font-mono text-emerald-400 font-black">{Math.floor(p.score)}</span>
                      <p className="text-[10px] text-slate-400 font-bold uppercase">Points</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    );
  }

  // --- VIEW PARTICIPANT ---
  if (role === 'participant') {
    if (!isJoined) {
      return (
        <div className="min-h-screen bg-amber-50 flex items-center justify-center p-6 font-sans">
          <div className="bg-white p-10 rounded-[40px] shadow-2xl w-full max-w-md text-center border-b-8 border-amber-500">
            <div className="w-24 h-24 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
              <User size={48} className="text-amber-600" />
            </div>
            <h2 className="text-3xl font-black text-slate-800 mb-3">Daftar Peserta</h2>
            <p className="text-slate-500 mb-8 font-medium">Tuliskan nama lengkapmu dengan benar.</p>
            <input 
              type="text"
              placeholder="Contoh: Siti Aisyah"
              className="w-full px-8 py-5 bg-slate-50 border-3 border-slate-100 focus:border-amber-500 rounded-3xl mb-6 outline-none transition text-xl font-bold text-slate-700 text-center"
              value={playerName}
              onChange={(e) => setPlayerName(e.target.value)}
            />
            <button 
              onClick={joinGame}
              disabled={!playerName.trim()}
              className="w-full py-5 bg-amber-500 hover:bg-amber-600 disabled:bg-slate-300 text-white font-black text-xl rounded-3xl shadow-xl shadow-amber-500/20 transition transform active:scale-95 uppercase tracking-wider"
            >
              IKUT LOMBA
            </button>
          </div>
        </div>
      );
    }

    if (isLocked) {
      return (
        <div className="min-h-screen bg-red-600 flex items-center justify-center p-8 text-white text-center font-sans">
          <div className="max-w-sm">
            <AlertTriangle size={100} className="mx-auto mb-8 animate-bounce" />
            <h1 className="text-5xl font-black mb-6 uppercase">AKSES DIBLOKIR!</h1>
            <p className="text-xl leading-relaxed font-bold opacity-90">
              Kamu terdeteksi mencoba membuka aplikasi lain atau keluar dari tab kuis.<br/><br/>
              Harap lapor ke panitia jika ini adalah kesalahan.
            </p>
          </div>
        </div>
      );
    }

    const currentQ = QUESTION_BANK[gameState?.currentQuestionIndex || 0];
    const hasAnswered = participants.find(p => p.id === user?.uid)?.hasAnswered;

    return (
      <div className="min-h-screen bg-white flex flex-col font-sans">
        {warningCount > 0 && !isLocked && (
          <div className="bg-red-600 text-white p-4 text-center flex items-center justify-center gap-3 animate-pulse font-black uppercase text-sm">
            <AlertTriangle size={20} /> JANGAN PINDAH TAB! PELANGGARAN: {warningCount}/3
          </div>
        )}

        <div className="bg-slate-900 p-5 shadow-xl flex justify-between items-center text-white">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center text-white font-black">
              {playerName.charAt(0).toUpperCase()}
            </div>
            <span className="font-black truncate max-w-[120px]">{playerName}</span>
          </div>
          <div className="bg-slate-800 px-4 py-2 rounded-xl text-sm font-black text-emerald-400 border border-slate-700">
             SOAL { (gameState?.currentQuestionIndex || 0) + 1 }
          </div>
        </div>

        <div className="flex-1 p-6 flex flex-col justify-center bg-slate-50">
          {gameState?.status === 'lobby' ? (
            <div className="text-center space-y-8 animate-in fade-in zoom-in">
              <div className="w-32 h-32 bg-emerald-100 rounded-full flex items-center justify-center mx-auto animate-pulse">
                <Timer size={64} className="text-emerald-600" />
              </div>
              <div>
                <h3 className="text-3xl font-black text-slate-800 mb-2">SIAP-SIAP!</h3>
                <p className="text-slate-500 font-bold px-4">Lomba akan dimulai sebentar lagi. Perhatikan layar di depan untuk membaca soal!</p>
              </div>
              <div className="bg-white p-6 rounded-3xl shadow-lg border-2 border-slate-100">
                <p className="text-slate-400 text-sm font-black uppercase mb-2">Instruksi:</p>
                <p className="text-slate-700 font-medium">Baca soal di layar depan, lalu tekan jawaban yang benar di HP ini secepat mungkin.</p>
              </div>
            </div>
          ) : gameState?.status === 'playing' ? (
            <div className="space-y-8">
              {hasAnswered ? (
                <div className="text-center space-y-6 animate-in slide-in-from-bottom duration-500">
                  <div className="w-24 h-24 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto shadow-inner">
                    <CheckCircle2 size={56} />
                  </div>
                  <div>
                    <h3 className="text-3xl font-black text-slate-800 uppercase tracking-tighter">Jawaban Terkunci</h3>
                    <p className="text-slate-500 font-bold mt-2">Menunggu waktu soal habis...</p>
                  </div>
                </div>
              ) : (
                <>
                  <div className="text-center">
                    <div className={`text-7xl font-mono font-black mb-2 ${gameState?.timeRemaining < 10 ? 'text-red-500 scale-110 transition-transform' : 'text-slate-800'}`}>
                      {gameState?.timeRemaining || 0}
                    </div>
                    <div className="h-1.5 w-full bg-slate-200 rounded-full overflow-hidden max-w-[200px] mx-auto">
                      <div 
                        className={`h-full transition-all duration-1000 ${gameState?.timeRemaining < 10 ? 'bg-red-500' : 'bg-emerald-500'}`}
                        style={{ width: `${((gameState?.timeRemaining || 0) / (currentQ?.timeLimit || 60)) * 100}%` }}
                      ></div>
                    </div>
                  </div>
                  
                  <div className="grid grid-cols-1 gap-4">
                    {['A', 'B', 'C', 'D'].map((label, i) => (
                      <button 
                        key={i}
                        onClick={() => submitAnswer(i)}
                        className="group flex items-center p-6 bg-white border-2 border-slate-200 hover:border-amber-500 active:bg-amber-50 rounded-[2rem] text-left transition-all shadow-md active:shadow-inner"
                      >
                        <div className="w-14 h-14 rounded-2xl bg-slate-100 group-hover:bg-amber-100 text-slate-600 group-hover:text-amber-600 flex items-center justify-center font-black text-3xl mr-6 shrink-0 transition-colors">
                          {label}
                        </div>
                        <span className="text-xl font-black text-slate-700 uppercase">Pilih {label}</span>
                      </button>
                    ))}
                  </div>
                </>
              )}
            </div>
          ) : (
            <div className="text-center space-y-8 animate-in bounce-in">
              <Award size={100} className="text-amber-500 mx-auto drop-shadow-lg" />
              <h3 className="text-4xl font-black text-slate-800 uppercase">SELESAI!</h3>
              <p className="text-slate-500 font-bold text-lg px-6">Alhamdulillah, perjuanganmu luar biasa! Lihat pengumuman di layar depan.</p>
              <div className="bg-amber-100 p-6 rounded-3xl text-amber-900 font-black text-xl shadow-inner border border-amber-200">
                LOMBA TELAH BERAKHIR
              </div>
            </div>
          )}
        </div>
      </div>
    );
  }
}
